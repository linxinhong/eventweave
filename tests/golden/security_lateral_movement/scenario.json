{
  "id": "security_lateral_movement",
  "name": "Lateral movement alert scenario",
  "domain": "security",
  "version": "1.0",
  "duration": "45m",
  "seed": 20260628,
  "for_each": "user",
  "entities": {
    "user": {
      "count": 5,
      "type": "user",
      "attributes": {},
      "tags": []
    },
    "host": {
      "count": 10,
      "type": "host",
      "attributes": {},
      "tags": []
    },
    "ip": {
      "count": 15,
      "type": "ip",
      "attributes": {},
      "tags": []
    },
    "alert": {
      "count": 3,
      "type": "alert",
      "attributes": {},
      "tags": []
    }
  },
  "sources": [
    {
      "id": "edr-001",
      "type": "security_device",
      "domain": null,
      "role": "edr",
      "rate": {
        "base_qps": 300.0,
        "burst_qps": 3000.0,
        "jitter": 0.15
      },
      "time_policy": {
        "mode": "realtime",
        "late_arrival_ratio": 0.0,
        "out_of_order_ratio": 0.0
      },
      "outputs": [
        {
          "type": "kafka",
          "topic": "mock.security.edr"
        }
      ]
    },
    {
      "id": "firewall-001",
      "type": "security_device",
      "domain": null,
      "role": "firewall",
      "rate": {
        "base_qps": 1000.0,
        "burst_qps": 8000.0,
        "jitter": 0.2
      },
      "time_policy": {
        "mode": "realtime",
        "late_arrival_ratio": 0.0,
        "out_of_order_ratio": 0.0
      },
      "outputs": [
        {
          "type": "syslog",
          "protocol": "udp",
          "address": "127.0.0.1:514"
        }
      ]
    }
  ],
  "timeline": [
    {
      "id": "failed_login",
      "event": "user.login.failed",
      "source": "edr-001",
      "at": "00:01:00",
      "after": null,
      "delay": null,
      "probability": 1.0,
      "repeat": 1,
      "semantic": null,
      "attributes": {
        "reason": "Invalid password"
      },
      "entity_refs": {
        "user": "$flow",
        "host": "$entity.host"
      },
      "labels": [],
      "ground_truth": {},
      "jitter": null
    },
    {
      "id": "successful_login",
      "event": "user.login.success",
      "source": "edr-001",
      "at": null,
      "after": "failed_login",
      "delay": "30s..2m",
      "probability": 1.0,
      "repeat": 1,
      "semantic": null,
      "attributes": {
        "method": "password"
      },
      "entity_refs": {
        "user": "$ref.failed_login.user",
        "host": "$ref.failed_login.host"
      },
      "labels": [],
      "ground_truth": {},
      "jitter": null
    },
    {
      "id": "suspicious_process",
      "event": "process.suspicious_started",
      "source": "edr-001",
      "at": null,
      "after": "successful_login",
      "delay": "5m..10m",
      "probability": 1.0,
      "repeat": 1,
      "semantic": null,
      "attributes": {
        "process_name": "powershell.exe",
        "command_line": "encoded command"
      },
      "entity_refs": {
        "host": "$ref.successful_login.host"
      },
      "labels": [],
      "ground_truth": {},
      "jitter": null
    },
    {
      "id": "lateral_connection",
      "event": "network.lateral_connection",
      "source": "firewall-001",
      "at": null,
      "after": "suspicious_process",
      "delay": "1m..3m",
      "probability": 1.0,
      "repeat": 1,
      "semantic": null,
      "attributes": {
        "port": 445,
        "protocol": "tcp"
      },
      "entity_refs": {
        "source_host": "$ref.suspicious_process.host",
        "target_host": "$entity.host",
        "source_ip": "$entity.ip",
        "target_ip": "$entity.ip"
      },
      "labels": [],
      "ground_truth": {},
      "jitter": null
    },
    {
      "id": "alert_triggered",
      "event": "alert.triggered",
      "source": "edr-001",
      "at": null,
      "after": "lateral_connection",
      "delay": "1m..5m",
      "probability": 1.0,
      "repeat": 1,
      "semantic": null,
      "attributes": {
        "severity": "high",
        "description": "Lateral movement detected"
      },
      "entity_refs": {
        "host": "$ref.lateral_connection.source_host",
        "alert": "$new.alert"
      },
      "labels": [],
      "ground_truth": {},
      "jitter": null
    }
  ],
  "semantic_tasks": [],
  "rules": [
    {
      "id": "login_success_after_failed_attempts",
      "type": "event_after",
      "event": "user.login.success",
      "after": "user.login.failed",
      "scope": "flow"
    },
    {
      "id": "alert_must_reference_existing_host",
      "type": "required_entity_ref",
      "event": "alert.triggered",
      "ref": "host"
    },
    {
      "id": "lateral_connection_must_reference_two_hosts",
      "type": "required_entity_ref",
      "event": "network.lateral_connection",
      "refs": [
        "source_host",
        "target_host"
      ]
    }
  ],
